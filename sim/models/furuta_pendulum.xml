<mujoco model="furuta_pendulum">
  <compiler angle="radian" meshdir="../meshes/"/>

  <option timestep="0.001" iterations="50" solver="Newton" tolerance="1e-10" integrator="implicit"/>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.1 0.1 0.1" rgb2="0.02 0.02 0.02" width="512" height="512"/>
    <texture name="texplane" builtin="checker" rgb1=".2 .3 .4" rgb2=".1 0.15 0.2" type="2d" width="512" height="512" mark="edge" markrgb=".8 .8 .8"/>  
    <material name="matplane" reflectance="0" texture="texplane" texrepeat="1 1" texuniform="true"/>
    
    <mesh name="base_link" content_type="model/stl" file="base_link.STL"/>
    <mesh name="rotor_link" content_type="model/stl" file="rotor_link.STL"/>
    <mesh name="rotating_base_link" content_type="model/stl" file="rotating_base_link.STL"/>
    <mesh name="pendulum_link" content_type="model/stl" file="pendulum_link.STL"/>
  </asset>

  <worldbody>
    <light directional="true" diffuse=".6 .6 .6" specular="0.2 0.2 0.2" pos="3 0 2" dir="-3 0 -2" castshadow="false"/>

    <geom type="mesh" contype="0" conaffinity="0" group="1" density="2700" rgba="0.094118 0.396078 0.592157 1" mesh="base_link"/>
    <geom type="mesh" contype="0" conaffinity="0" rgba="0.094118 0.396078 0.592157 0.8" mesh="base_link"/>

    <body name="rotor_link" pos="0 0 0.16509" quat="-2.6569e-06 -0.723319 -0.690514 -2.5364e-06">
      
      <joint name="rotor_joint" pos="0 0 0" axis="0 0 1" damping="0.0025" armature="0.0005" frictionloss="0.0025"/>
      
      <geom type="mesh" contype="0" conaffinity="0" group="1" mass="0.005" rgba="0.094118 0.396078 0.592157 1" mesh="rotor_link"/>
      <geom type="mesh" contype="0" conaffinity="0" rgba="0.094118 0.396078 0.592157 1" mesh="rotor_link"/>

      <geom pos="0.00052307 0 -0.020976" quat="1.34925e-11 3.67321e-06 1 3.67321e-06" type="mesh" contype="0" conaffinity="0" group="1" mass="0.075" rgba="0.094118 0.396078 0.592157 1" mesh="rotating_base_link"/>
      <geom pos="0.00052307 0 -0.020976" quat="1.34925e-11 3.67321e-06 1 3.67321e-06" type="mesh" contype="0" conaffinity="0" rgba="0.094118 0.396078 0.592157 1" mesh="rotating_base_link"/>
      
      <body name="pendulum_link" pos="5.95127e-07 0.0810093 -0.0546994" quat="3.67321e-06 -1 0 -2.69849e-11">
        <inertial mass="0.2" pos="0 0 -0.115" diaginertia="0.00004 0.00004 0.00001"/>
  
        <joint name="pendulum_joint" pos="0 0 0" axis="0 1 0" damping="0.0005" frictionloss="0.0008"  armature="0.00001" stiffness="0" ref="3.14159265"/>
      
        <geom type="mesh" contype="0" conaffinity="0" group="1" rgba="0.792157 0.819608 0.933333 1" mesh="pendulum_link"/>
        <geom type="mesh" contype="0" conaffinity="0" rgba="0.792157 0.819608 0.933333 1" mesh="pendulum_link"/>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="arm_motor" joint="rotor_joint" gear="0.353" ctrlrange="-1.5 1.5" ctrllimited="true"/>
  </actuator>

  <sensor>
    <jointpos name="rotor_angle" joint="rotor_joint"/>
    <jointvel name="rotor_vel" joint="rotor_joint"/>
    
    <jointpos name="pendulum_angle" joint="pendulum_joint"/>
    <jointvel name="pendulum_vel" joint="pendulum_joint"/>
  </sensor>


</mujoco>
